POSTGRES_DB=agent_network
POSTGRES_OWNER_USER=agent_owner
POSTGRES_OWNER_PASSWORD=change-this-local-owner-password
POSTGRES_APP_USER=agent_app
POSTGRES_APP_PASSWORD=change-this-local-app-password
POSTGRES_READONLY_USER=agent_readonly
POSTGRES_READONLY_PASSWORD=change-this-local-readonly-password
POSTGRES_BIND_ADDRESS=127.0.0.1
POSTGRES_HOST_PORT=55432
DATABASE_URL=postgresql+psycopg://agent_app:change-this-local-app-password@postgres:5432/agent_network
DATABASE_MIGRATION_URL=postgresql+psycopg://agent_owner:change-this-local-owner-password@postgres:5432/agent_network
DATABASE_SSL_MODE=prefer
DATABASE_SSL_ROOT_CERT=
DATABASE_SSL_CERT=
DATABASE_SSL_KEY=
BACKUP_ENCRYPTION_PASSPHRASE=
KAFKA_BOOTSTRAP_SERVERS=redpanda:9092
KAFKA_ENABLED=true
JWT_SECRET_KEY=replace-with-a-long-random-secret
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
VITE_API_BASE_URL=http://127.0.0.1:8000
