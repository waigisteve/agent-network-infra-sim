Enum role {
  admin
  field_agent
  agent
  kyc_reviewer
}

Enum compliance_status {
  pending
  approved
  rejected
}

Enum float_request_status {
  pending
  approved
  rejected
}

Enum partner_type {
  telco
  bank
  agent_app
}

Enum integration_mode {
  kafka
  sftp
  api
  database_replica
}

Enum integration_run_status {
  received
  validated
  loaded
  reconciled
  failed
}

TableGroup "PostgreSQL security controls" {
  users
  field_agents
  agents
  customers
  float_requests
  transactions
  event_log
  security_audit_log
  analytics_snapshots
  worker_errors
  partners
  partner_contracts
  integration_runs
  raw_partner_transactions
  bank_settlements
  reconciliation_exceptions
}

TableGroup "dbt analytics marts" {
  dim_agents
  dim_partners
  fact_partner_transactions
  mart_partner_network_health
  mart_liquidity_risk
}

Note: '''
Database role model:
- agent_owner owns schema objects and runs Alembic through DATABASE_MIGRATION_URL.
- agent_app is the runtime API/worker role from DATABASE_URL and receives SELECT, INSERT, UPDATE, DELETE grants.
- agent_readonly is for reporting/audit access and receives SELECT grants only.
- agent_auditor is an optional fresh-volume role for narrow SELECT access on event_log and security_audit_log.

Security controls:
- All application tables have ENABLE ROW LEVEL SECURITY and FORCE ROW LEVEL SECURITY from migration 0002_postgres_security.
- Each table receives an *_app_rw policy for runtime reads/writes and an *_readonly policy for SELECT-only access.
- Network access is constrained by pg_hba.conf and SCRAM-SHA-256 authentication.
- TLS parameters are supplied by DATABASE_SSL_MODE and certificate path variables.
- Encrypted logical backups are produced by scripts/encrypted_pg_backup.sh.
- pgAudit, firewall/private networking, and encryption at rest are hosted database controls.
'''

Table users [note: 'Forced RLS. Policies: users_app_rw for agent_app read/write; users_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  email varchar(255) [unique, not null]
  full_name varchar(255) [not null]
  password_hash varchar(255) [not null]
  role role [not null]
  agent_id varchar(64)
  is_active boolean [not null]
  created_at timestamp [not null]

  indexes {
    email [unique]
    role
    agent_id
    (role, is_active)
  }
}

Table field_agents [note: 'Forced RLS. Policies: field_agents_app_rw for agent_app read/write; field_agents_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  name varchar(255) [not null]
  region varchar(255) [not null]
  phone varchar(64) [not null]
}

Table agents [note: 'Forced RLS. Policies: agents_app_rw for agent_app read/write; agents_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  name varchar(255) [not null]
  field_agent_id varchar(64) [not null]
  outlet varchar(255) [not null]
  float_balance integer [not null, default: 0]
  cash_balance integer [not null, default: 0]
  outstanding_balance integer [not null, default: 0]
  latitude float [not null]
  longitude float [not null]

  indexes {
    field_agent_id
    (field_agent_id, name)
    (latitude, longitude)
  }
}

Table customers [note: 'Forced RLS. Policies: customers_app_rw for agent_app read/write; customers_readonly for SELECT. PII is stored here and masked at the API boundary. Owner: agent_owner.'] {
  id varchar(64) [pk]
  name varchar(255) [not null]
  surname varchar(255) [not null]
  phone varchar(64) [not null]
  birthday varchar(64) [not null]
  national_id varchar(128) [not null]
  nationality varchar(128) [not null]
  address text [not null]
  compliance_status compliance_status [not null, default: 'pending']
  kyc_collected_by varchar(255) [not null]
  verified_at timestamp
  compliance_comments text

  indexes {
    phone
    (compliance_status, verified_at)
    (name, surname)
  }
}

Table float_requests [note: 'Forced RLS. Policies: float_requests_app_rw for agent_app read/write; float_requests_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  agent_id varchar(64) [not null]
  amount integer [not null]
  request_type varchar(32) [not null, default: 'float']
  status float_request_status [not null, default: 'pending']
  requested_at timestamp [not null]
  reviewed_by varchar(255)
  reviewed_at timestamp

  indexes {
    agent_id
    status
    requested_at
    (status, requested_at)
    (agent_id, status)
  }
}

Table transactions [note: 'Forced RLS. Policies: transactions_app_rw for agent_app read/write; transactions_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  agent_id varchar(64) [not null]
  customer_id varchar(64)
  customer_phone varchar(64) [not null]
  transaction_type varchar(64) [not null]
  amount integer [not null]
  commission integer [not null, default: 0]
  created_at timestamp [not null]
  status varchar(64) [not null, default: 'posted']

  indexes {
    agent_id
    customer_id
    customer_phone
    transaction_type
    created_at
    (agent_id, created_at)
    (customer_id, created_at)
    (transaction_type, created_at)
    (customer_phone, created_at)
  }
}

Table event_log [note: 'Forced RLS. Policies: event_log_app_rw for agent_app read/write; event_log_readonly for SELECT. Audit events are persisted here before/alongside Kafka publishing. Owner: agent_owner.'] {
  id varchar(64) [pk]
  topic varchar(128) [not null]
  name varchar(128) [not null]
  aggregate_type varchar(64)
  aggregate_id varchar(64)
  agent_id varchar(64)
  customer_id varchar(64)
  float_request_id varchar(64)
  transaction_id varchar(64)
  payload json [not null]
  created_at timestamp [not null]

  indexes {
    topic
    name
    aggregate_type
    aggregate_id
    agent_id
    customer_id
    float_request_id
    transaction_id
    created_at
    (topic, created_at)
    (name, created_at)
    (aggregate_type, aggregate_id)
  }
}

Table security_audit_log [note: 'Forced RLS. Security audit rows for failed login, unauthorized, and forbidden API attempts. Secrets, JWTs, and raw request bodies are not stored.'] {
  id varchar(64) [pk]
  event_type varchar(128) [not null]
  outcome varchar(64) [not null]
  user_id varchar(64)
  email varchar(255)
  role role
  method varchar(16) [not null]
  path varchar(255) [not null]
  client_host varchar(128)
  detail text [not null]
  created_at timestamp [not null]

  indexes {
    event_type
    outcome
    user_id
    path
    (event_type, created_at)
    (outcome, created_at)
    (user_id, created_at)
  }
}

Table analytics_snapshots [note: 'Forced RLS. Policies: analytics_snapshots_app_rw for agent_app read/write; analytics_snapshots_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  snapshot_date date [not null]
  scope varchar(64) [not null, default: 'network']
  agent_id varchar(64)
  field_agent_id varchar(64)
  metrics json [not null]
  created_at timestamp [not null]

  indexes {
    snapshot_date
    scope
    agent_id
    field_agent_id
    (scope, snapshot_date)
    (agent_id, snapshot_date)
    (field_agent_id, snapshot_date)
  }
}

Table worker_errors [note: 'Forced RLS. Policies: worker_errors_app_rw for agent_app read/write; worker_errors_readonly for SELECT. Owner: agent_owner.'] {
  id varchar(64) [pk]
  event_id varchar(64)
  source varchar(128) [not null]
  message text [not null]
  payload json
  created_at timestamp

  indexes {
    event_id
    source
    created_at
    (source, created_at)
  }
}

Table partners [note: 'Forced RLS. External telco, bank, or agent-app source. Captures country, integration mode, freshness SLA, and active state.'] {
  id varchar(64) [pk]
  code varchar(64) [unique, not null]
  name varchar(255) [not null]
  partner_type partner_type [not null]
  country varchar(64) [not null]
  integration_mode integration_mode [not null]
  data_freshness_sla_minutes integer [not null]
  is_active boolean [not null]
  created_at timestamp [not null]

  indexes {
    code [unique]
    partner_type
    country
    integration_mode
    is_active
    (partner_type, country)
  }
}

Table partner_contracts [note: 'Forced RLS. Versioned feed contract for required fields, accepted values, dedupe keys, PII fields, and arrival SLA.'] {
  id varchar(64) [pk]
  partner_id varchar(64) [not null]
  feed_name varchar(128) [not null]
  version varchar(32) [not null]
  schema_contract json [not null]
  pii_fields json [not null]
  dedupe_key json [not null]
  arrival_sla varchar(64) [not null]
  is_active boolean [not null]
  created_at timestamp [not null]

  indexes {
    partner_id
    feed_name
    is_active
    (partner_id, is_active)
    (partner_id, feed_name, version) [unique]
  }
}

Table integration_runs [note: 'Forced RLS. Audit record for every partner file, API pull, Kafka window, or replica extract.'] {
  id varchar(64) [pk]
  partner_id varchar(64) [not null]
  contract_id varchar(64)
  feed_name varchar(128) [not null]
  source_reference varchar(255) [not null]
  status integration_run_status [not null]
  records_received integer [not null]
  records_loaded integer [not null]
  records_rejected integer [not null]
  error_summary text
  started_at timestamp [not null]
  completed_at timestamp

  indexes {
    partner_id
    contract_id
    feed_name
    status
    (partner_id, started_at)
    (status, started_at)
    (partner_id, feed_name, source_reference) [unique]
  }
}

Table raw_partner_transactions [note: 'Forced RLS. Canonical raw telco transaction feed with hashed customer identifier and immutable raw payload.'] {
  id varchar(64) [pk]
  partner_id varchar(64) [not null]
  integration_run_id varchar(64) [not null]
  provider_reference varchar(128) [not null]
  agent_id varchar(64) [not null]
  customer_msisdn_hash varchar(128) [not null]
  transaction_type varchar(64) [not null]
  amount integer [not null]
  commission integer [not null]
  status varchar(64) [not null]
  transaction_created_at timestamp [not null]
  raw_payload json [not null]
  loaded_at timestamp [not null]

  indexes {
    partner_id
    integration_run_id
    provider_reference
    agent_id
    customer_msisdn_hash
    transaction_type
    status
    transaction_created_at
    (partner_id, provider_reference) [unique]
    (partner_id, transaction_created_at)
    (agent_id, transaction_created_at)
  }
}

Table bank_settlements [note: 'Forced RLS. Bank settlement totals used to reconcile transaction count, gross value, commission, and currency.'] {
  id varchar(64) [pk]
  partner_id varchar(64) [not null]
  integration_run_id varchar(64) [not null]
  settlement_reference varchar(128) [not null]
  settlement_date date [not null]
  transaction_count integer [not null]
  gross_amount integer [not null]
  commission_amount integer [not null]
  currency varchar(8) [not null]
  raw_payload json [not null]
  loaded_at timestamp [not null]

  indexes {
    partner_id
    integration_run_id
    settlement_reference
    (partner_id, settlement_reference) [unique]
    (partner_id, settlement_date)
  }
}

Table reconciliation_exceptions [note: 'Forced RLS. Exception queue for settlement mismatch, missing file, duplicate reference, or SLA breach investigations.'] {
  id varchar(64) [pk]
  partner_id varchar(64) [not null]
  integration_run_id varchar(64)
  exception_type varchar(128) [not null]
  severity varchar(32) [not null]
  status varchar(32) [not null]
  description text [not null]
  evidence json [not null]
  created_at timestamp [not null]

  indexes {
    partner_id
    integration_run_id
    exception_type
    severity
    status
    (partner_id, status)
    (exception_type, created_at)
  }
}

Table dim_agents [note: 'dbt mart in analytics_marts. Governed agent dimension for BI and partner/customer-facing reporting.'] {
  agent_id varchar(64) [pk]
  agent_name varchar(255)
  outlet varchar(255)
  field_agent_id varchar(64)
  field_agent_name varchar(255)
  region varchar(255)
  latitude float
  longitude float
  float_balance integer
  cash_balance integer
  outstanding_balance integer
}

Table dim_partners [note: 'dbt mart in analytics_marts. Governed partner dimension used for tenant-aware reporting and Superset RLS.'] {
  partner_id varchar(64) [pk]
  partner_code varchar(64)
  partner_name varchar(255)
  partner_type partner_type
  country varchar(64)
  integration_mode integration_mode
  data_freshness_sla_minutes integer
  is_active boolean
}

Table fact_partner_transactions [note: 'dbt mart fact_transactions. Trusted deduplicated transaction fact built from raw_partner_transactions.'] {
  transaction_key varchar(64) [pk]
  partner_id varchar(64)
  provider_reference varchar(128)
  agent_id varchar(64)
  customer_msisdn_hash varchar(128)
  transaction_type varchar(64)
  amount integer
  commission integer
  transaction_status varchar(64)
  transaction_created_at timestamp
  loaded_at timestamp
}

Table mart_partner_network_health [note: 'dbt mart for customer-facing partner health dashboards in Superset.'] {
  partner_id varchar(64) [pk]
  partner_code varchar(64)
  partner_name varchar(255)
  country varchar(64)
  transaction_volume integer
  transaction_value integer
  commission_value integer
  active_agents integer
  failed_transactions integer
  latest_loaded_at timestamp
}

Table mart_liquidity_risk [note: 'dbt mart for operations and working-capital dashboards.'] {
  agent_id varchar(64) [pk]
  agent_name varchar(255)
  region varchar(255)
  float_balance integer
  cash_balance integer
  recent_transaction_volume integer
  recent_transaction_value integer
  liquidity_risk varchar(32)
}

Ref: users.agent_id > agents.id
Ref: agents.field_agent_id > field_agents.id
Ref: float_requests.agent_id > agents.id
Ref: transactions.agent_id > agents.id
Ref: transactions.customer_id > customers.id
Ref: event_log.agent_id > agents.id
Ref: event_log.customer_id > customers.id
Ref: event_log.float_request_id > float_requests.id
Ref: event_log.transaction_id > transactions.id
Ref: security_audit_log.user_id > users.id
Ref: analytics_snapshots.agent_id > agents.id
Ref: analytics_snapshots.field_agent_id > field_agents.id
Ref: worker_errors.event_id > event_log.id
Ref: partner_contracts.partner_id > partners.id
Ref: integration_runs.partner_id > partners.id
Ref: integration_runs.contract_id > partner_contracts.id
Ref: raw_partner_transactions.partner_id > partners.id
Ref: raw_partner_transactions.integration_run_id > integration_runs.id
Ref: raw_partner_transactions.agent_id > agents.id
Ref: bank_settlements.partner_id > partners.id
Ref: bank_settlements.integration_run_id > integration_runs.id
Ref: reconciliation_exceptions.partner_id > partners.id
Ref: reconciliation_exceptions.integration_run_id > integration_runs.id
Ref: dim_agents.agent_id > agents.id
Ref: dim_agents.field_agent_id > field_agents.id
Ref: dim_partners.partner_id > partners.id
Ref: fact_partner_transactions.partner_id > dim_partners.partner_id
Ref: fact_partner_transactions.agent_id > dim_agents.agent_id
Ref: mart_partner_network_health.partner_id > dim_partners.partner_id
Ref: mart_liquidity_risk.agent_id > dim_agents.agent_id
